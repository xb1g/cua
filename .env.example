LIGHTCONE_API_KEY=sk_replace_me
TZAFON_API_KEY=sk_replace_me
KERNEL_API_KEY=sk_replace_me
MINIMAX_API_KEY=sk-minimax-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me

# =============================================================================
# CUA MODEL PROVIDER — Choose your agent model
# =============================================================================
#   northstar  — Tzafon Northstar via Lightcone API (default)
#   fireworks  — Kimi K2.6 Turbo via Fireworks AI (OpenAI-compatible)
#
# For Kimi K2.6 Turbo via Fireworks:
#   CUA_MODEL_PROVIDER=fireworks
#   FIREWORKS_API_KEY=fpk_xxx
#   FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
#   FIREWORKS_MODEL=accounts/fireworks/routers/kimi-k2p6-turbo
#
CUA_MODEL_PROVIDER=northstar

# =============================================================================
# Validator / Guider Model (optional — for intelligent validation & guidance)
# =============================================================================
# Set to 'kimi' to use Kimi K2.6 Turbo as a validator/guider while Northstar
# handles browser control. Set to 'local' (default) for cheap heuristics only.
VALIDATOR_PROVIDER=local
VALIDATOR_API_KEY=fpk_replace_me
VALIDATOR_BASE_URL=https://api.fireworks.ai/inference/v1
VALIDATOR_MODEL=accounts/fireworks/routers/kimi-k2p6-turbo

# =============================================================================
# Fireworks AI / Kimi K2.6 Turbo Settings
# =============================================================================
FIREWORKS_API_KEY=fpk_replace_me
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/routers/kimi-k2p6-turbo

# Optional overrides
BROWSER_BACKEND=kernel
SCANNER_MODEL=claude-haiku-4-5-20251001
NORTHSTAR_MODEL=tzafon.northstar-cua-fast
VERIFIER_MODEL=MiniMax-M2.7-highspeed
CUA_DISPLAY_WIDTH=1280
CUA_DISPLAY_HEIGHT=720
CUA_MAX_STEPS=40
CUA_MAX_ATTEMPTS=5
CUA_TRAJ_DIR=trajectories

# AEGIS feature flags (all default to true)
AEGIS_MARKETPLACE_MODE=true
AEGIS_DOM_EXTRACTION=true
AEGIS_APPROVAL_TIMEOUT=60
AEGIS_WIDTH=3
AEGIS_ALLOW_DANGEROUS_ACTIONS=false
